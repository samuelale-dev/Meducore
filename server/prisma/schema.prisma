datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     String
}

model Student {
  id        String   @id @default(cuid())
  studentId Int      @unique
  fullName  String
  createdAt DateTime @default(now())
}